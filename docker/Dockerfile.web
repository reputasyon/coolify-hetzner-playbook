# Web (static SPA) service — the second of TWO separate Coolify apps.
# Builds the Vite app and serves it with nginx. No API code, no API env vars —
# that separation is the point (see docs/two-apps-two-dockerfiles.md).

# --- Build stage ---
FROM node:24-alpine AS build

WORKDIR /app

COPY package.json package-lock.json ./
COPY api/package.json ./api/
COPY web/package.json ./web/

ENV NODE_ENV=development
RUN npm ci

COPY tsconfig.json ./
COPY web/ ./web/

# Vite envs are BUILD-TIME: they get baked into the bundle here.
# ⚠️ Coolify gotcha: setting these in the Coolify UI as runtime envs is NOT
# enough — each one must be declared as ARG here AND set as a build variable
# in Coolify, or it silently ends up undefined in the bundle.
ARG VITE_API_URL
# CHANGE ME: declare every VITE_* your app reads

RUN npm run build -w web

# --- Serve stage ---
FROM nginx:alpine

COPY --from=build /app/web/dist /usr/share/nginx/html
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
